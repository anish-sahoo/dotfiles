#!/usr/bin/env python3
import subprocess
import re
import pandas as pd
import sys

def parse_caddyfile(caddyfile_path="/etc/caddy/Caddyfile"):
    mapping = {}
    all_domains = set()
    current_domain = None
    inside_tls_block = False

    with open(caddyfile_path, "r") as file:
        for line in file:
            line = line.strip()

            if not line or line.startswith("#"):
                continue

            if line.startswith("tls {"):
                inside_tls_block = True
                continue
            if inside_tls_block:
                if line == "}":
                    inside_tls_block = False
                continue

            if re.match(r"^[\w\.-]+\s*\{?$", line):
                current_domain = line.split()[0]
                all_domains.add(current_domain)
                continue

            if current_domain and "reverse_proxy" in line:
                match = re.search(r"reverse_proxy\s+localhost:(\d+)", line)
                if match:
                    port = int(match.group(1))
                    mapping[current_domain] = port

    return mapping, all_domains

def get_docker_ports():
    cmd = ['docker', 'ps', '--format', '{{.Names}}:::{{.Ports}}']
    output = subprocess.check_output(cmd).decode().splitlines()
    containers = {}
    for line in output:
        name, ports_raw = line.split(":::", 1)
        ports = re.findall(r'(\d+)->\d+/tcp', ports_raw)
        containers[name] = [int(p) for p in ports] if ports else []
    return containers

def generate_mapping(caddy_map, all_domains, docker_map):
    data = []
    used_ports = set(caddy_map.values())
    seen = set()

    for domain, port in caddy_map.items():
        container = next((c for c, ps in docker_map.items() if port in ps), "Unknown")
        data.append({
            "URL": domain,
            "Application / Container Name": container,
            "Port(s)": port,
            "Mapped via Caddy": "✅ Yes"
        })
        seen.add((container, port))

    for domain in all_domains:
        if domain not in caddy_map:
            data.append({
                "URL": domain,
                "Application / Container Name": "(none)",
                "Port(s)": "(none)",
                "Mapped via Caddy": "⚠ No reverse_proxy"
            })

    for name, ports in docker_map.items():
        if ports:
            for port in set(ports):
                if port not in used_ports and (name, port) not in seen:
                    data.append({
                        "URL": "(none)",
                        "Application / Container Name": name,
                        "Port(s)": port,
                        "Mapped via Caddy": "❌ No"
                    })
                    seen.add((name, port))
        else:
            data.append({
                "URL": "(none)",
                "Application / Container Name": name,
                "Port(s)": "(none)",
                "Mapped via Caddy": "❌ No ports"
            })

    return pd.DataFrame(data)

def main():
    caddy_map, all_domains = parse_caddyfile()
    docker_map = get_docker_ports()
    df = generate_mapping(caddy_map, all_domains, docker_map)
    df["Port(s)"] = pd.to_numeric(df["Port(s)"], errors="coerce")
    df.sort_values(by=["Port(s)", "URL"], inplace=True, na_position='last')

    markdown_output = df.to_markdown(index=False)

    # Pipe the markdown to glow
    try:
        proc = subprocess.run(['glow', '-w', '150'], input=markdown_output.encode(), check=True)
    except FileNotFoundError:
        print("Error: 'glow' not found. Please install glow or run without piping.", file=sys.stderr)
        print(markdown_output)
    except subprocess.CalledProcessError as e:
        print(f"Error running glow: {e}", file=sys.stderr)
        print(markdown_output)

if __name__ == "__main__":
    main()
